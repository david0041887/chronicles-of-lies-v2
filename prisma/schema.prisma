// Chronicles of Lies — Prisma Schema (Phase 0 skeleton)
// Aligned with §3 Data Models in the spec. Will expand per-phase.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// User
// ============================================================
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  avatar       String?
  avatarFrame  String?

  // Level & exp
  level        Int      @default(1)
  exp          Int      @default(0)
  title        String   @default("新生編織者")

  // Currencies
  crystals     Int      @default(300)
  faith        Int      @default(0)
  essence      Int      @default(0)
  masks        Int      @default(0)
  scrolls      Int      @default(0)

  // Faction
  faction      Faction  @default(weavers)

  // Global resource
  veilEnergy   Int      @default(0)

  // Stats
  battlesWon       Int @default(0)
  battlesLost      Int @default(0)
  totalBelievers   Int @default(0)
  cardsCollected   Int @default(0)

  // Social
  covenId      String?
  coven        Coven?   @relation(fields: [covenId], references: [id])

  // IAP
  councilRank  Int      @default(0)
  totalSpent   Int      @default(0)

  // Gacha pity counters
  pitySR       Int      @default(0)  // rolls since last SR+
  pitySSR      Int      @default(0)  // rolls since last SSR+
  pityUR       Int      @default(0)  // rolls since last UR
  totalPulls   Int      @default(0)

  // Guest / device binding
  deviceId     String?  @unique
  isGuest      Boolean  @default(false)

  // Tutorial & milestone rewards
  tutorialDone      Boolean  @default(false)
  freePulls         Int      @default(0)
  /** Which Deck slot (1..3) is used in battles. Players can save up to
   *  3 decks and switch between them; defaults to slot 1 which is the
   *  auto-migrated deck for existing users. */
  activeDeckSlot    Int      @default(1)
  claimedMilestones String[] @default([])

  // Daily missions — JSON: { date: "YYYY-MM-DD", slots: [{id, progress, target, claimed}, ...] }
  dailyMissions     Json     @default("{}")

  // Era-specific gacha tickets — JSON: { [eraId]: count }
  // Earned via BOSS first-clear (5) and repeat clear (1); spent on era pool
  // instead of crystals.
  eraTickets        Json     @default("{}")

  // Spread-lies cooldown (global across eras)
  lastSpreadAt      DateTime?

  // Timestamps
  createdAt    DateTime @default(now())
  lastLoginAt  DateTime @default(now())

  // Relations
  ownedCards     OwnedCard[]
  decks          Deck[]
  eraProgress    EraProgress[]
  dungeonRuns    DungeonRun[]
  startingReward StartingReward?
}

enum Faction {
  weavers
  veritas
  faceless
}

enum Role {
  USER
  ADMIN
}

// ============================================================
// Coven (guild)
// ============================================================
model Coven {
  id        String   @id @default(cuid())
  name      String   @unique
  emblem    String?
  createdAt DateTime @default(now())
  members   User[]
}

// ============================================================
// Card (template) + OwnedCard (instance)
// ============================================================
model Card {
  id          String   @id // e.g. "ssr_egypt_001_anubis"
  name        String
  nameEn      String?
  title       String?  // 稱號
  eraId       String   // E01..E15 or R01..R03
  rarity      Rarity
  element     Element
  type        CardType @default(attack)
  faction     Faction?
  power       Int
  cost        Int      @default(1)
  keywords    String[] @default([])
  flavor      String?  // 卡面下方風味文字
  description String?
  lore        String?  // 典藏故事
  imageUrl    String?
  createdAt   DateTime @default(now())

  corrupted   Boolean  @default(false)  // 黑化神話:覺醒版變體(scaffold)
  ownedBy     OwnedCard[]
  image       CardImage?

  @@index([rarity])
  @@index([eraId])
}

// Separate table so default Card queries don't pull multi-KB image blobs.
model CardImage {
  cardId    String   @id
  bytes     Bytes
  mime      String   @default("image/jpeg")
  prompt    String?  // stored for audit / regeneration
  provider  String   @default("cloudflare")
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

enum CardType {
  attack
  spread
  heal
  confuse
  buff
  debuff
  ritual
}

enum Rarity {
  R
  SR
  SSR
  UR
}

enum Element {
  light
  dark
  flux
  order
  desire
  illusion
  end
}

model OwnedCard {
  id       String @id @default(cuid())
  userId   String
  cardId   String
  level    Int    @default(1)
  stars    Int    @default(1)
  awakened Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id])

  @@index([userId])
  @@index([cardId])
  // Hot path: collection + deck pages filter by userId then group/lookup
  // by cardId. Composite index covers both predicates with one seek
  // instead of @@index([userId]) + row-level filter.
  @@index([userId, cardId])
}

// ============================================================
// Deck
// ============================================================
model Deck {
  id        String   @id @default(cuid())
  userId    String
  name      String
  eraId     String?  // dominant era (for resonance)
  cardIds   String[] // ordered list of OwnedCard ids
  /** Slot index 1..3 — players can keep up to 3 saved decks. Slot 1 is
   *  auto-created at first save; the active one (per User.activeDeckSlot)
   *  is what battles draw from. */
  slot      Int      @default(1)
  createdAt DateTime @default(now())
  // @default(now()) handles the backfill on existing rows; @updatedAt
  // keeps it auto-bumped on subsequent updates.
  updatedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slot])
  @@index([userId])
}

// ============================================================
// StageClear — per-user per-stage history (first-clear bonus)
// ============================================================
model StageClear {
  id              String   @id @default(cuid())
  userId          String
  stageId         String
  firstClearedAt  DateTime @default(now())
  lastClearedAt   DateTime @default(now())
  clearCount      Int      @default(1)

  @@unique([userId, stageId])
  @@index([userId])
}

// ============================================================
// Stage — PvE battle definitions (per era)
// ============================================================
model Stage {
  id              String   @id            // e.g. "egypt_1"
  eraId           String
  orderNum        Int      @default(1)    // ordering within era
  name            String
  subtitle        String?
  difficulty      Int      @default(1)    // 1 easy .. 10 nightmare
  enemyHp         Int      @default(50)
  enemyName       String
  enemyDeck       String[]                // card ids, size 15-30
  rewardCrystals  Int      @default(50)
  rewardExp       Int      @default(0)    // DEPRECATED: weaver level now driven by believers only
  rewardBelievers Int      @default(200)
  isBoss          Boolean  @default(false)
  mode            StageMode @default(normal)   // scaffold: normal / prime / hunt
  createdAt       DateTime @default(now())

  @@index([eraId, orderNum])
  @@index([mode])
  // /era/[id] and battle stage routing filter by (eraId, mode) constantly;
  // composite avoids scanning every stage for the era to find the prime
  // subset (and vice versa).
  @@index([eraId, mode, orderNum])
}

enum StageMode {
  normal
  prime  // 二週目 / Prime Mode (harder variant)
  hunt   // 守真者獵殺 (Veritas Hunt)
}

// ============================================================
// AuditLog — append-only security / admin event trail
// ============================================================
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  // null for system / anonymous events
  action    String   // e.g. "admin.grantCrystals", "battle.reject", "bind.attempt"
  ip        String?  // x-forwarded-for / x-real-ip when available
  meta      Json?    // action-specific detail (target id, amount, reason)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// ============================================================
// StartingReward — new-user 200-pull gift (5 rounds × 4 choices)
// ============================================================
model StartingReward {
  id        String    @id @default(cuid())
  userId    String    @unique
  // rolls: 5 rounds, each with 4 choices, each choice = 10 card ids
  // Serialized as JSON: string[][][] shape [5][4][10]
  rolls     Json
  // picks[round] = chosen choice index (0-3); length grows 0→5
  picks     Int[]     @default([])
  claimedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// Per-era progress
// ============================================================
// ============================================================
// Dungeon — Tower of Whispers (and future: Hunt, Abyss, Inquisition)
//
// One row per active run per (user, dungeon kind). The row is
// re-used as the player ascends floors; a successful clear bumps
// `level`, a defeat resets it to 0 and stamps `lastResetAt`.
//
// `state` is opaque JSON for per-dungeon-kind extras (cumulative HP
// carry-over for Abyss, faction-rep for Inquisition, etc.) so we
// don't need a column-per-feature schema migration each time we add
// a dungeon kind.
// ============================================================
model DungeonRun {
  id            String   @id @default(cuid())
  userId        String
  kind          DungeonKind
  level         Int      @default(0)        // current floor (0 = not yet entered today)
  highestLevel  Int      @default(0)        // best floor ever reached (for vanity / stats)
  lastFloorAt   DateTime?                   // when the player last cleared a floor
  lastResetAt   DateTime?                   // when the run last reset (defeat or weekly tick)
  totalClears   Int      @default(0)        // lifetime floor-clear count for this kind
  state         Json     @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind])
  @@index([userId])
}

enum DungeonKind {
  tower         // 幽音塔 — endless vertical gauntlet
  hunt          // 共鳴獵殺 — weekly legend raid (scaffold)
  abyss         // 深淵回響 — boss gauntlet w/ state carry (scaffold)
  inquisition   // 守真者審判 — choice-based campaign (scaffold)
}

model EraProgress {
  id             String @id @default(cuid())
  userId         String
  eraId          String
  believers      Int    @default(0)
  dominantLegend Int?   // 0..3, index of legend with most spreads
  bossCleared    Boolean @default(false)
  highestStage   Int    @default(0)

  // Per-legend spread counters (4 values, matching eras.ts legends[0..3])
  legendCounts   Int[]  @default([])
  // Total spreads across all 4 legends in this era (denormalized for UI)
  spreadsTotal   Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eraId])
  @@index([userId])
}
